# Auto detect text files and normalize
* text=auto

# Java / Gradle / configs (LF padrão)
*.java text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Shell scripts (LF obrigatório)
*.sh text eol=lf

# Windows scripts (CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf

# Imagens/binários (não mexer)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary
*.zip binary
